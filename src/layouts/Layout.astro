---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Passmore Bookkeeping & Tax Solutions',
  description = 'Expert bookkeeping, tax filing, and payroll services for individuals and businesses across Mission and the Fraser Valley.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- GSAP -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" is:inline></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" is:inline></script>

    <style is:global>
      html {
        scroll-behavior: smooth;
      }
      body {
        font-family: 'Inter', system-ui, sans-serif;
        background-color: #071322;
        color: #f5f3ef;
        overflow-x: hidden;
      }
      h1, h2, h3 {
        font-family: 'Playfair Display', Georgia, serif;
      }
      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          transition-duration: 0.01ms !important;
        }
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
