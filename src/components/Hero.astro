---
---

<section
  id="hero"
  class="relative min-h-screen flex items-center justify-center overflow-hidden"
>
  <!-- Background: layered geometric gradient -->
  <div class="absolute inset-0 bg-navy"></div>
  <div class="absolute inset-0" style="background: radial-gradient(ellipse 80% 60% at 70% 50%, rgba(207,186,137,0.08) 0%, transparent 70%);"></div>
  <div class="absolute inset-0" style="background: radial-gradient(ellipse 60% 80% at 20% 80%, rgba(13,32,53,0.9) 0%, transparent 60%);"></div>

  <!-- Decorative line -->
  <div class="absolute top-0 right-0 w-px h-full bg-gradient-to-b from-transparent via-gold/20 to-transparent hidden lg:block"></div>
  <div class="absolute top-0 left-[60%] w-px h-full bg-gradient-to-b from-transparent via-gold/10 to-transparent hidden lg:block"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-6xl mx-auto px-6 py-32 md:py-40">
    <div class="max-w-3xl">
      <!-- Eyebrow -->
      <p
        id="hero-eyebrow"
        class="text-gold text-sm font-medium tracking-[0.3em] uppercase mb-6 opacity-0"
      >
        Mission, BC &mdash; Fraser Valley
      </p>

      <!-- Headline -->
      <h1
        id="hero-headline"
        class="font-serif text-5xl md:text-6xl lg:text-7xl font-bold text-cream leading-tight mb-6 opacity-0"
      >
        Financial Clarity<br />
        <span class="text-gold">for Your Business</span><br />
        &amp; Life.
      </h1>

      <!-- Subline -->
      <p
        id="hero-sub"
        class="text-cream/70 text-lg md:text-xl font-light leading-relaxed max-w-xl mb-10 opacity-0"
      >
        Bookkeeping, tax filing, and payroll services — handled with precision and care, so you can focus on what's important to you.
      </p>

      <!-- CTAs -->
      <div id="hero-cta" class="flex flex-col sm:flex-row gap-4 opacity-0">
        <a
          href="tel:6048209791"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-gold text-navy font-semibold tracking-wide hover:bg-gold-light transition-all duration-300 group"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          604-820-9791
        </a>
        <a
          href="#contact"
          class="inline-flex items-center justify-center px-8 py-4 border border-cream/30 text-cream font-medium tracking-wide hover:border-gold hover:text-gold transition-all duration-300"
        >
          Get in Touch
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-60">
    <span class="text-cream text-xs tracking-widest uppercase">Scroll</span>
    <div class="w-px h-12 bg-gradient-to-b from-cream/60 to-transparent animate-pulse"></div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof gsap === 'undefined') return;

    gsap.to('#hero-eyebrow', { opacity: 1, y: 0, duration: 0.8, delay: 0.3, ease: 'power3.out', from: { y: 20 } });
    gsap.fromTo('#hero-headline', { opacity: 0, y: 40 }, { opacity: 1, y: 0, duration: 1, delay: 0.5, ease: 'power3.out' });
    gsap.fromTo('#hero-sub', { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 0.9, delay: 0.8, ease: 'power3.out' });
    gsap.fromTo('#hero-cta', { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.8, delay: 1.1, ease: 'power3.out' });
  });
</script>
