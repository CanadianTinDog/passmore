---
const year = new Date().getFullYear();
---

<footer class="bg-navy border-t border-cream/10 py-12">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-3 gap-10 mb-10">
      <!-- Brand -->
      <div>
        <img src="/images/logo.png" alt="Passmore Bookkeeping & Tax Solutions" class="h-10 w-auto mb-4" />
        <p class="text-cream/40 text-sm leading-relaxed max-w-xs">
          Bookkeeping, tax, and payroll services for individuals and businesses across Mission and the Fraser Valley.
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <p class="text-gold text-xs font-medium tracking-[0.2em] uppercase mb-5">Quick Links</p>
        <nav class="flex flex-col gap-3">
          <a href="#services" class="text-cream/50 text-sm hover:text-gold transition-colors">Services</a>
          <a href="#about" class="text-cream/50 text-sm hover:text-gold transition-colors">About Kira</a>
          <a href="#why" class="text-cream/50 text-sm hover:text-gold transition-colors">Why Passmore</a>
          <a href="#contact" class="text-cream/50 text-sm hover:text-gold transition-colors">Contact</a>
        </nav>
      </div>

      <!-- Contact -->
      <div>
        <p class="text-gold text-xs font-medium tracking-[0.2em] uppercase mb-5">Contact</p>
        <div class="space-y-3">
          <a href="tel:6048209791" class="flex items-center gap-2 text-cream/50 text-sm hover:text-gold transition-colors">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            604-820-9791
          </a>
          <a href="mailto:kira@passmorebookkeeping.ca" class="flex items-center gap-2 text-cream/50 text-sm hover:text-gold transition-colors">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            kira@passmorebookkeeping.ca
          </a>
          <p class="text-cream/30 text-sm">Mission, BC &mdash; Fraser Valley</p>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-cream/10 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-cream/30 text-xs">
        &copy; {year} Passmore Bookkeeping & Tax Solutions. All rights reserved.
      </p>
      <p class="text-cream/20 text-xs">Mission, British Columbia, Canada</p>
    </div>
  </div>
</footer>
