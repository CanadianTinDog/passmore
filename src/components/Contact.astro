---
---

<section id="contact" class="bg-cream py-24 md:py-32">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-12 lg:gap-20">

      <!-- Left: info -->
      <div class="contact-info">
        <p class="text-gold-dark text-sm font-medium tracking-[0.3em] uppercase mb-4">Get in Touch</p>
        <h2 class="font-serif text-4xl md:text-5xl text-navy font-bold leading-tight mb-6">
          Let's Talk About<br />Your Finances
        </h2>
        <div class="w-16 h-px bg-gold-dark mb-8"></div>

        <p class="text-navy/60 leading-relaxed mb-10">
          Whether you're an individual navigating tax season or a business owner who needs reliable books, we're here to help. Reach out — we'll get back to you promptly.
        </p>

        <div class="space-y-6">
          <a
            href="tel:6048209791"
            class="flex items-center gap-4 group"
          >
            <div class="w-12 h-12 border border-navy/20 flex items-center justify-center text-gold-dark group-hover:bg-navy group-hover:border-navy group-hover:text-gold transition-all duration-300">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-navy/40 uppercase tracking-wider mb-0.5">Phone</p>
              <p class="text-navy font-medium group-hover:text-gold-dark transition-colors">604-820-9791</p>
            </div>
          </a>

          <a
            href="mailto:kira@passmorebookkeeping.ca"
            class="flex items-center gap-4 group"
          >
            <div class="w-12 h-12 border border-navy/20 flex items-center justify-center text-gold-dark group-hover:bg-navy group-hover:border-navy group-hover:text-gold transition-all duration-300">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-navy/40 uppercase tracking-wider mb-0.5">Email</p>
              <p class="text-navy font-medium group-hover:text-gold-dark transition-colors">kira@passmorebookkeeping.ca</p>
            </div>
          </a>
        </div>
      </div>

      <!-- Right: form -->
      <div class="contact-form">
        <form
          id="contact-form"
          x-data="{
            sending: false,
            sent: false,
            error: false,
            async submit(e) {
              this.sending = true;
              this.error = false;
              const form = e.target;
              const data = new FormData(form);
              try {
                const res = await fetch('https://api.web3forms.com/submit', {
                  method: 'POST',
                  body: data,
                });
                const json = await res.json();
                if (json.success) {
                  this.sent = true;
                  form.reset();
                } else {
                  this.error = true;
                }
              } catch {
                this.error = true;
              } finally {
                this.sending = false;
              }
            }
          }"
          @submit.prevent="submit($event)"
          class="space-y-5"
        >
          <!-- Web3Forms access key — client replaces this with their key from web3forms.com -->
          <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_ACCESS_KEY" />
          <input type="hidden" name="subject" value="New inquiry from Passmore Bookkeeping website" />
          <input type="checkbox" name="botcheck" class="hidden" style="display:none;" />

          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="name" class="block text-xs font-medium tracking-wider uppercase text-navy/50 mb-2">Full Name</label>
              <input
                id="name" name="name" type="text" required
                class="w-full px-4 py-3 bg-white border border-navy/20 text-navy placeholder-navy/30 focus:outline-none focus:border-gold-dark transition-colors text-sm"
                placeholder="Jane Smith"
              />
            </div>
            <div>
              <label for="email" class="block text-xs font-medium tracking-wider uppercase text-navy/50 mb-2">Email</label>
              <input
                id="email" name="email" type="email" required
                class="w-full px-4 py-3 bg-white border border-navy/20 text-navy placeholder-navy/30 focus:outline-none focus:border-gold-dark transition-colors text-sm"
                placeholder="jane@example.com"
              />
            </div>
          </div>

          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="phone" class="block text-xs font-medium tracking-wider uppercase text-navy/50 mb-2">Phone <span class="normal-case font-normal">(optional)</span></label>
              <input
                id="phone" name="phone" type="tel"
                class="w-full px-4 py-3 bg-white border border-navy/20 text-navy placeholder-navy/30 focus:outline-none focus:border-gold-dark transition-colors text-sm"
                placeholder="604-555-0100"
              />
            </div>
            <div>
              <label for="service" class="block text-xs font-medium tracking-wider uppercase text-navy/50 mb-2">I'm interested in</label>
              <select
                id="service" name="service"
                class="w-full px-4 py-3 bg-white border border-navy/20 text-navy focus:outline-none focus:border-gold-dark transition-colors text-sm appearance-none"
              >
                <option value="">Select a service</option>
                <option value="Personal Income Tax">Personal Income Tax</option>
                <option value="Business Bookkeeping">Business Bookkeeping</option>
                <option value="Corporate Tax">Corporate Tax</option>
                <option value="Payroll">Payroll</option>
                <option value="Other">Other / Not Sure</option>
              </select>
            </div>
          </div>

          <div>
            <label for="message" class="block text-xs font-medium tracking-wider uppercase text-navy/50 mb-2">Message</label>
            <textarea
              id="message" name="message" rows="4" required
              class="w-full px-4 py-3 bg-white border border-navy/20 text-navy placeholder-navy/30 focus:outline-none focus:border-gold-dark transition-colors text-sm resize-none"
              placeholder="Tell us a bit about what you need..."
            ></textarea>
          </div>

          <button
            type="submit"
            :disabled="sending"
            class="w-full py-4 bg-navy text-cream font-medium tracking-wider uppercase text-sm hover:bg-navy-mid transition-colors duration-300 disabled:opacity-60"
          >
            <span x-show="!sending && !sent">Send Message</span>
            <span x-show="sending">Sending...</span>
            <span x-show="sent">Message Sent ✓</span>
          </button>

          <p x-show="sent" class="text-green-700 text-sm text-center">
            Thank you — we'll be in touch shortly.
          </p>
          <p x-show="error" class="text-red-600 text-sm text-center">
            Something went wrong. Please call or email us directly.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
    gsap.registerPlugin(ScrollTrigger);

    gsap.fromTo(
      '.contact-info',
      { opacity: 0, x: -40 },
      {
        opacity: 1, x: 0, duration: 0.9, ease: 'power3.out',
        scrollTrigger: { trigger: '#contact', start: 'top 75%', toggleActions: 'play none none reverse' },
      }
    );

    gsap.fromTo(
      '.contact-form',
      { opacity: 0, x: 40 },
      {
        opacity: 1, x: 0, duration: 0.9, ease: 'power3.out',
        scrollTrigger: { trigger: '#contact', start: 'top 75%', toggleActions: 'play none none reverse' },
      }
    );
  });
</script>
